# Convex backend (set in Convex dashboard → Settings → Environment Variables)
CLERK_JWT_ISSUER_DOMAIN=https://....clerk.accounts.dev
OPENROUTER_API_KEY=
# Identity `.convex.site` URL — server-side debits via /api/credits/*
IDENTITY_CONVEX_SITE_URL=
# Prefer per-app secret (must match Identity `CREDITS_SERVICE_SECRET_DEBATES`)
CREDITS_SERVICE_SECRET_DEBATES=
# Legacy fallback shared secret
CREDITS_SERVICE_SECRET=
# Set to "true" to deduct credits on paid actions. Unset or "false" skips debits (testing).
CREDITS_ENFORCEMENT=
